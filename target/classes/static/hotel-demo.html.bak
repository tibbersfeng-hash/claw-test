    <script>
        // ========== Data ==========
        const hotels = {
            '北京': [
                { id: 1, name: '北京香格里拉大酒店', brand: '香格里拉酒店', addr: '海淀区紫竹院路29号', rating: 4.8, reviews: 2156, price: 1288, img: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&h=400&fit=crop', tags: ['免费WiFi', '游泳池', '健身房'] },
                { id: 2, name: '北京国贸大酒店', brand: '香格里拉酒店', addr: '朝阳区建国门外大街1号', rating: 4.9, reviews: 1892, price: 1588, img: 'https://images.unsplash.com/photo-1582719508461-905c673771fd?w=600&h=400&fit=crop', tags: ['免费WiFi', '行政酒廊'] },
                { id: 3, name: '北京嘉里大酒店', brand: '嘉里酒店', addr: '朝阳区光华路1号', rating: 4.7, reviews: 1234, price: 1088, img: 'https://images.unsplash.com/photo-1564501049412-61c2a3083791?w=600&h=400&fit=crop', tags: ['免费WiFi', '儿童乐园'] }
            ],
            '上海': [
                { id: 4, name: '上海浦东香格里拉大酒店', brand: '香格里拉酒店', addr: '浦东新区富城路33号', rating: 4.9, reviews: 3245, price: 1688, img: 'https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=600&h=400&fit=crop', tags: ['免费WiFi', '江景房', '游泳池'] },
                { id: 5, name: '上海静安香格里拉大酒店', brand: '香格里拉酒店', addr: '静安区延安中路1218号', rating: 4.8, reviews: 2567, price: 1388, img: 'https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=600&h=400&fit=crop', tags: ['免费WiFi', '行政酒廊'] },
                { id: 6, name: '上海虹桥康得思酒店', brand: '嘉里酒店', addr: '闵行区虹桥商务区', rating: 4.7, reviews: 1567, price: 1188, img: 'https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?w=600&h=400&fit=crop', tags: ['免费WiFi', 'SPA'] }
            ],
            '香港': [
                { id: 7, name: '香港香格里拉大酒店', brand: '香格里拉酒店', addr: '金钟太古广场', rating: 4.9, reviews: 4567, price: 2288, img: 'https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=600&h=400&fit=crop', tags: ['免费WiFi', '游泳池', '海景'] },
                { id: 8, name: '香港港岛香格里拉大酒店', brand: '香格里拉酒店', addr: '中环金融街', rating: 4.8, reviews: 3456, price: 1988, img: 'https://images.unsplash.com/photo-1564501049412-61c2a3083791?w=600&h=400&fit=crop', tags: ['免费WiFi', '行政酒廊'] }
            ],
            '新加坡': [
                { id: 9, name: '新加坡香格里拉大酒店', brand: '香格里拉酒店', addr: '乌节路22号', rating: 4.9, reviews: 5678, price: 2588, img: 'https://images.unsplash.com/photo-1582719508461-905c673771fd?w=600&h=400&fit=crop', tags: ['免费WiFi', '游泳池', '花园'] }
            ]
        };

        const rooms = [
            { name: '豪华客房', size: '45㎡', bed: '大床', guests: 2, price: 1288, img: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=400&h=300&fit=crop', facilities: ['免费WiFi', '早餐'] },
            { name: '行政客房', size: '52㎡', bed: '大床', guests: 2, price: 1688, img: 'https://images.unsplash.com/photo-1591088398332-8a7791972843?w=400&h=300&fit=crop', facilities: ['免费WiFi', '早餐', '酒廊'] },
            { name: '豪华套房', size: '85㎡', bed: '大床', guests: 3, price: 2888, img: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=400&h=300&fit=crop', facilities: ['免费WiFi', '早餐', '客厅'] },
            { name: '总统套房', size: '150㎡', bed: '大床', guests: 4, price: 8888, img: 'https://images.unsplash.com/photo-1591088398332-8a7791972843?w=400&h=300&fit=crop', facilities: ['免费WiFi', '早餐', '管家服务'] }
        ];

        // ========== State ==========
        let currentDest = '';
        let currentHotel = null;
        let currentRoom = null;
        let currentSort = 'recommend';

        // ========== Navigation ==========
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0, 0);
        }

        // ========== Destination Selection ==========
        function selectDest(name, count) {
            currentDest = name;
            document.getElementById('selected-dest').textContent = name;
            showPage('page-home');
            showToast(`已选择: ${name}`);
        }

        function filterDest(region) {
            document.querySelectorAll('.dest-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
        }

        // ========== Hotel List ==========
        function searchHotels() {
            if (!currentDest) {
                showToast('请先选择目的地');
                return;
            }
            renderHotelList();
            showPage('page-hotel-list');
        }

        function renderHotelList() {
            const list = document.getElementById('hotel-list');
            const title = document.getElementById('hotel-list-title');
            const hotelData = hotels[currentDest] || hotels['北京'];

            title.textContent = `${currentDest || '北京'}的酒店`;

            let sortedData = [...hotelData];
            if (currentSort === 'price-asc') {
                sortedData.sort((a, b) => a.price - b.price);
            } else if (currentSort === 'price-desc') {
                sortedData.sort((a, b) => b.price - a.price);
            } else if (currentSort === 'rating') {
                sortedData.sort((a, b) => b.rating - a.rating);
            }

            list.innerHTML = sortedData.map(hotel => `
                <div class="hotel-card" onclick="showHotelDetail(${hotel.id})">
                    <img class="hotel-img" src="${hotel.img}" alt="${hotel.name}">
                    <div class="hotel-info">
                        <div class="hotel-brand">${hotel.brand}</div>
                        <div class="hotel-name">${hotel.name}</div>
                        <div class="hotel-addr">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            ${hotel.addr}
                        </div>
                        <div class="hotel-tags">
                            ${hotel.tags.map(t => `<span class="hotel-tag">${t}</span>`).join('')}
                        </div>
                        <div class="hotel-bottom">
                            <div class="hotel-rating">
                                <span class="rating-badge">★ ${hotel.rating}</span>
                                <span class="rating-count">${hotel.reviews.toLocaleString()}条评价</span>
                            </div>
                            <div class="hotel-price">
                                <div class="price-label">每晚最低</div>
                                <span class="price-value">¥${hotel.price.toLocaleString()}</span>
                                <span class="price-unit">起</span>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function filterHotels(type, btn) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
            renderHotelList();
        }

        // ========== Hotel Detail ==========
        function showHotelDetail(id) {
            const hotelData = hotels[currentDest] || hotels['北京'];
            currentHotel = hotelData.find(h => h.id === id) || hotelData[0];

            document.getElementById('detail-img').src = currentHotel.img;
            document.getElementById('detail-brand').textContent = currentHotel.brand;
            document.getElementById('detail-name').textContent = currentHotel.name;
            document.getElementById('detail-rating').textContent = currentHotel.rating;
            document.getElementById('detail-rating-count').textContent = currentHotel.reviews.toLocaleString() + '条评价';
            document.getElementById('detail-addr').textContent = currentHotel.addr;
            document.getElementById('detail-price').textContent = '¥' + currentHotel.price.toLocaleString();

            showPage('page-hotel-detail');
        }

        function toggleFavorite(el) {
            el.classList.toggle('favorited');
            const svg = el.querySelector('svg');
            if (el.classList.contains('favorited')) {
                svg.setAttribute('fill', 'currentColor');
                showToast('已添加到收藏');
            } else {
                svg.setAttribute('fill', 'none');
                showToast('已取消收藏');
            }
        }

        // ========== Room List ==========
        function renderRoomList() {
            const list = document.getElementById('room-list');
            document.getElementById('room-hotel-name').textContent = currentHotel ? currentHotel.name : '北京香格里拉大酒店';

            list.innerHTML = rooms.map(room => `
                <div class="room-card">
                    <img class="room-img" src="${room.img}" alt="${room.name}">
                    <div class="room-info">
                        <div class="room-name">${room.name}</div>
                        <div class="room-size">${room.size} · ${room.bed} · 可住${room.guests}人</div>
                        <div class="room-facilities">
                            ${room.facilities.map(f => `<span class="room-facility">${f}</span>`).join('')}
                        </div>
                        <div class="room-card-bottom">
                            <div class="room-price">
                                <span class="room-price-label">每晚</span>
                                <div class="room-price-row">
                                    <span class="room-price-value">¥${room.price.toLocaleString()}</span>
                                </div>
                            </div>
                            <button class="room-book-btn" onclick="selectRoom('${room.name}', ${room.price})">预订</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Override the showPage to render room list when showing that page
        const originalShowPage = showPage;
        showPage = function(pageId) {
            originalShowPage(pageId);
            if (pageId === 'page-room-list') {
                renderRoomList();
            }
        };

        function selectRoom(name, price) {
            currentRoom = { name, price };
            document.getElementById('confirm-hotel').textContent = currentHotel ? currentHotel.name : '北京香格里拉大酒店';
            document.getElementById('confirm-room').textContent = name;
            document.getElementById('confirm-price').textContent = '¥' + price.toLocaleString();
            document.getElementById('confirm-total').textContent = '¥' + price.toLocaleString();
            showPage('page-booking-confirm');
        }

        // ========== Booking ==========
        function submitBooking() {
            showToast('预订成功！确认邮件已发送至您的邮箱');
            setTimeout(() => {
                showPage('page-home');
            }, 2000);
        }

        // ========== Sort Panel ==========
        function showSortPanel() {
            document.getElementById('overlay').classList.add('active');
            document.getElementById('sortPanel').classList.add('active');
        }

        function hideSortPanel() {
            document.getElementById('overlay').classList.remove('active');
            document.getElementById('sortPanel').classList.remove('active');
        }

        function selectSort(el, sortType) {
            document.querySelectorAll('.sort-option').forEach(o => o.classList.remove('active'));
            el.classList.add('active');
            currentSort = sortType;
            setTimeout(() => {
                hideSortPanel();
                renderHotelList();
            }, 200);
        }

        // ========== Toast ==========
        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 2000);
        }

        // ========== Nav Scroll Effect ==========
        window.addEventListener('scroll', function() {
            const nav = document.querySelector('#page-home .nav');
            if (nav && document.getElementById('page-home').classList.contains('active')) {
                if (window.scrollY > 100) {
                    nav.classList.remove('transparent');
                    nav.classList.add('white');
                } else {
                    nav.classList.remove('white');
                    nav.classList.add('transparent');
                }
            }
        });

        // ========== Bottom Navigation ==========
        function navigateTo(pageId, el) {
            document.querySelectorAll('.bottom-nav-item').forEach(item => item.classList.remove('active'));
            if (el) el.classList.add('active');
            showPage(pageId);
        }

        function showAccount() {
            showToast('请先登录您的账户');
        }

        // ========== Membership ==========
        function showMemberDetail(level) {
            const levelNames = {
                'jade': '翡翠会员',
                'diamond': '钻石会员',
                'gold': '黑金会员'
            };
            showToast(`查看${levelNames[level]}详情`);
        }

        // ========== Offers ==========
        function filterOffers(type) {
            document.querySelectorAll('.offers-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
        }

        function showOfferDetail(id) {
            showToast('查看优惠详情');
        }

        // ========== Dining ==========
        function showDiningDetail(id) {
            showToast('查看餐厅详情');
        }

        // ========== Hide booking widget on certain pages ==========
        const originalShowPage2 = showPage;
        showPage = function(pageId) {
            originalShowPage2(pageId);

            // Hide booking widget on non-home pages
            const bookingWidget = document.querySelector('.booking-widget');
            const bottomNav = document.getElementById('bottom-nav');

            if (pageId === 'page-home') {
                if (bookingWidget) bookingWidget.style.display = 'block';
                if (bottomNav) bottomNav.style.display = 'flex';
            } else {
                if (bookingWidget) bookingWidget.style.display = 'none';
            }

            // Show bottom nav on membership, offers, dining pages
            const showBottomNavPages = ['page-home', 'page-membership', 'page-offers', 'page-dining'];
            if (bottomNav) {
                bottomNav.style.display = showBottomNavPages.includes(pageId) ? 'flex' : 'none';
            }
        };
    </script>
</body>
</html>